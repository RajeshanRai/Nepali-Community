# Django Settings
# Copy this file to .env and fill in your production values

# SECURITY: Generate a secure SECRET_KEY in production
# Linux/Mac: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# Windows PowerShell: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secure-secret-key-here

# Set to False in production
DEBUG=False

# Add your production domains here, comma-separated
# Example: ALLOWED_HOSTS=nepalicommunityvancouver.ca,www.nepalicommunityvancouver.ca,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/nepali_community

